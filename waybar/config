{
    "gtk-layer-shell": false,
    "layer": "top",
    "modules-left": ["tray","cpu","memory","temperature"],
    "modules-center": ["river/tags"],
    "modules-right": ["group/audio", "backlight", "network", "clock", "battery"],

    "group/audio": {
        "orientation": "horizontal",
        "modules": [
            "upower",
            "pulseaudio",
        ]
    },

    "upower": {
        "native-path": "/org/bluez/hci0/dev_EC_66_D1_B8_FC_A0",
        "hide-if-empty": false,
        "tooltip": false,
        "format": "{percentage} ",
        "show-icon": false
    },

    "pulseaudio": {
        // "scroll-step": 1, // %, can be a float
        "format": "{icon} {volume}% {format_source}",
        "format-bluetooth": "{icon}ΎΛΦ {volume}% {format_source}",
        "format-bluetooth-muted": "{icon}ΎΛΦ≤░╕Ι  {format_source}",
        "format-muted": "≤░╕Ι {format_source}",
        "format-source": "ΎΕ░ {volume}%",
        "format-source-muted": "ΎΕ▒",
        "format-icons": {
            "headphones": "ΎΑξ",
            "handsfree": "ΎΨΡ",
            "headset": "ΎΨΡ",
            "phone": "ΎΓΧ",
            "phone-muted": "Ό┤Ω",
            "portable": "ΎΓΧ",
            "car": "ΎΗ╣",
            "default": ["ΎΑο", "ΎΑπ", "ΎΑρ"]
        },
        "on-click": "pavucontrol"
    },
    "river/tags": {
        "num-tags": 9,
    },
    "wlr/workspaces": {
        "sort-by-name": true,
        "on-click": "activate",
        "all-outputs": true,
    },
    "river/window": {
        "format": "{}"
    },
    "network": {
        "tooltip": false,
        "format": "{icon}",
        "format-alt": "{ipaddr} {icon}",
        "format-alt-click": "click-right",
        "format-ethernet": "{icon}",
        "format-wifi": " {icon}",
        "format-disconnected": "{icon}",
        "format-icons": {
            "wifi": [
                "≤░νψ ",
                "≤░νθ ",
                "≤░νλ ",
                "≤░νλ ",
                "≤░νρ ",
                "≤░νρ "
            ],
            "ethernet": ["≤░ΙΑ"],
            "disconnected": ["ΎΕπ "],
        },
    },
    "backlight": {
        "tooltip": false,
        "interval": 1,
        "format": "ΎΔτ {percent}%",
        "on-scroll-up": "brightnessctl s +5%",
        "on-scroll-down": "brightnessctl s 5%-",
        "smooth-scrolling-threshold": 1,
    },
    "battery": {
        "states": {
            "good": 95,
            "warning": 30,
            "critical": 20,
        },
        "format": "{icon}  {capacity}%",
        "format-charging": "ΎΘο {capacity}%",
        "format-plugged": "ΎΘο {capacity}%",
        "format-alt": "{time} {icon}",
        "format-icons": ["ΎΚΕ", "ΎΚΔ", "ΎΚΓ", "ΎΚΒ", "ΎΚΑ"],
    },
    "tray":{
        "icon-size": 18,
        "spacing": 10,
    },
    "clock": {
        "format": "ΎΑΩ {0:%H:%M} ≤░╕α {0:%d.%m.%y}",
        "tooltip-format": "<tt><small>{calendar}</small></tt>",
        "calendar": {
            "mode"          : "year",
            "mode-mon-col"  : 3,
            "weeks-pos"     : "right",
            "on-scroll"     : 1,
            "on-click-right": "mode",
            "format": {
                "months":     "<span color='#ffead3'><b>{}</b></span>",
                "days":       "<span color='#ecc6d9'><b>{}</b></span>",
                "weeks":      "<span color='#99ffdd'><b>W{}</b></span>",
                "weekdays":   "<span color='#ffcc66'><b>{}</b></span>",
                "today":      "<span color='#ff6699'><b><u>{}</u></b></span>"
            }
        },
        "actions":  {
            "on-click-right": "mode",
            "on-click-forward": "tz_up",
            "on-click-backward": "tz_down",
            "on-scroll-up": "shift_up",
            "on-scroll-down": "shift_down",
        },
    },
    "cpu": {
        "format": "ΎΜδ {usage}%",
    },
    "memory": {
        "format": "ΎΔΚ {}%"
    },
    "temperature": {
        "tooltip": false,
        // "thermal-zone": 2,
        // "hwmon-path": "/sys/class/hwmon/hwmon2/temp1_input",
        "critical-threshold": 80,
        // "format-critical": "{temperatureC}┬░C {icon}",
        "format": "ΎΜΚ {temperatureC}┬░C",
    },
}
